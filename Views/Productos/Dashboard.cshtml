@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
    var nombres = ViewBag.Nombres as List<string>;
    var cantidades = ViewBag.Cantidades as List<int>;
}

<div class="container mt-4">
    <h2>Dashboard de Inventario</h2>

    <div class="row">
        <div class="col-md-6">
            <canvas id="inventarioBarChart"></canvas>
        </div>
        <div class="col-md-6">
            <canvas id="inventarioPieChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Gráfico de Barras
    const ctxBar = document.getElementById('inventarioBarChart').getContext('2d');
    new Chart(ctxBar, {
        type: 'bar',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(nombres)),
            datasets: [{
                label: 'Cantidad de Productos',
                data: @Html.Raw(JsonSerializer.Serialize(cantidades)),
                backgroundColor: 'rgba(54, 162, 235, 0.6)',
                borderColor: 'rgba(54, 162, 235, 1)',
                borderWidth: 1
            }]
        }
    });

    // Gráfico de Pastel
    const ctxPie = document.getElementById('inventarioPieChart').getContext('2d');
    new Chart(ctxPie, {
        type: 'pie',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(nombres)),
            datasets: [{
                label: 'Distribución de Inventario',
                data: @Html.Raw(JsonSerializer.Serialize(cantidades)),
                backgroundColor: [
                    'rgba(255, 99, 132, 0.6)',
                    'rgba(54, 162, 235, 0.6)',
                    'rgba(255, 206, 86, 0.6)',
                    'rgba(75, 192, 192, 0.6)',
                    'rgba(153, 102, 255, 0.6)',
                    'rgba(255, 159, 64, 0.6)'
                ]
            }]
        }
    });
</script>
}
